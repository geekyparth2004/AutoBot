{
  "manifest_version": 3,
  "name": "Amdocs Training Bot",
  "version": "0.1.0",
  "description": "Automates Amdocs course playback until course progress reaches 100%.",
  "permissions": ["storage", "activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
